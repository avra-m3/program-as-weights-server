# Optional: sign in for higher PAW compile rate limits (20/hr -> 60/hr) and
# named slugs. Everything works without it.
# Generate a key at https://programasweights.com/settings
# PAW_API_KEY=paw_sk_...

# Force CPU-only inference if GPU/Metal/CUDA causes issues.
# PAW_GPU_LAYERS=0

# Override where PAW caches downloaded models/programs (default: ~/.cache/programasweights/)
# PAW_CACHE_DIR=.paw_cache
